# ─── Supabase — <Project Name> (<Region>) ───
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>

# ─── Database (PostgreSQL, direct connection) ───
# NOT used by the Flutter app. Only for admin/migration scripts.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Gemini API ───
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# ─── Companion: also create .env.example (same structure, no secrets) ───
# This file is NEVER committed — ensure .env is in .gitignore
